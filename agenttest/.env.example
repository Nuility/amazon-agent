# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 批量操作限制
AGENTTEST_MAX_BATCH_SIZE=1000

# 日志级别
AGENTTEST_LOG_LEVEL=INFO

# 大模型API配置
AGENTTEST_LLM_API_KEY=your-api-key-here
AGENTTEST_LLM_API_ENDPOINT=https://api.openai.com/v1
AGENTTEST_LLM_MODEL=gpt-3.5-turbo

# 存储类型
AGENTTEST_STORAGE_TYPE=file

# 数据文件路径
AGENTTEST_DATA_FILE_PATH=./data/users.json
